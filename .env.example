# Server
NODE_ENV=development
PORT=3001

# Database
DATABASE_URL=postgresql://starter:starter_dev@localhost:5434/starter

# Redis
REDIS_URL=redis://localhost:6380

# JWT
JWT_ACCESS_SECRET=change-me-use-at-least-32-characters-here
JWT_REFRESH_SECRET=change-me-use-different-secret-than-above

# OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend
RESEND_API_KEY=re_...

# CORS
CORS_ORIGINS=http://localhost:5173

# Sentry (optional)
SENTRY_DSN=
